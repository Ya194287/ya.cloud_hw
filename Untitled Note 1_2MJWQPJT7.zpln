      "text": "%spark.pyspark\r\nfrom pyspark.sql import functions as F\r\n\r\n# Сохранение в HDFS\r\nhdfs_path = \"/tmp/sandbox_zeppelin/mart_city_top_products\"\r\ntop2_final.write.mode(\"overwrite\").parquet(hdfs_path)\r\nprint(\"Данные сохранены в HDFS\")\r\n\r\n# Сохранение в S3\r\ns3_path = \"s3a://defaultback/mart_city_top_products\"\r\ntop2_final.write.mode(\"overwrite\").parquet(s3_path)\r\nprint(\"Данные сохранены в S3\")\r\n\r\nprint(\"\\nЧитаем из HDFS:\")\r\nspark.read.parquet(hdfs_path).orderBy(\"city\", F.col(\"revenue_sum\").desc()).show()\r\n\r\nprint(\"Читаем из S3:\")\r\nspark.read.parquet(s3_path).orderBy(\"city\", F.col(\"revenue_sum\").desc()).show()",
