    {
      "text": "%spark.pyspark\r\nfrom pyspark.sql import functions as F\r\n\r\n# 1. Рассчитываем revenue = qty * price\r\norders_with_revenue = orders.withColumn(\"revenue\", F.col(\"qty\") * F.col(\"price\"))\r\n\r\nprint(\"Заказы с рассчитанным revenue:\")\r\norders_with_revenue.show()\r\n\r\n# 2. Объединяем orders с users (по user_id)\r\norders_users = orders_with_revenue.join(users, on=\"user_id\", how=\"inner\")\r\n\r\nprint(\"После объединения с users:\")\r\norders_users.show()\r\n\r\n# 3. Объединяем с products (по product_id)\r\nfull_df = orders_users.join(products, on=\"product_id\", how=\"inner\")\r\n\r\nprint(\"Итоговый DataFrame после всех объединений:\")\r\nfull_df.show()\r\n\r\nprint(\"Схема данных:\")\r\nfull_df.printSchema()",
      "user": "anonymous",
