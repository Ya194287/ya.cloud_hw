      "$$hashKey": "object:995",
      "text": "%spark.pyspark\r\nfrom pyspark.sql import functions as F\r\n\r\n# Агрегация по city, product_id, product_name\r\nagg_df = full_df.groupBy(\"city\", \"product_id\", \"product_name\").agg(\r\n    F.count(\"order_id\").alias(\"orders_cnt\"),\r\n    F.sum(\"qty\").alias(\"qty_sum\"),\r\n    F.sum(\"revenue\").alias(\"revenue_sum\")\r\n)\r\n\r\nprint(\"Агрегированные данные по городам и продуктам:\")\r\nagg_df.show()\r\n\r\n# Для наглядности отсортируем по городу и убыванию выручки\r\nagg_df.orderBy(\"city\", F.col(\"revenue_sum\").desc()).show()\r\n\r\nprint(\"Количество записей после агрегации:\", agg_df.count())",
      "dateUpdated": "2026-03-02T11:54:16+0000",
      "dateFinished": "2026-03-02T11:54:21+0000",
      "dateStarted": "2026-03-02T11:54:16+0000",
      "results": {
        "code": "SUCCESS",
        "msg": [
          {
            "type": "TEXT",
            "data": "Агрегированные данные по городам и продуктам:\n+-------+----------+------------+----------+-------+-----------+\n|   city|product_id|product_name|orders_cnt|qty_sum|revenue_sum|\n+-------+----------+------------+----------+-------+-----------+\n|Hamburg|        p1|   Ring VOLA|         1|     10|      100.0|\n| Berlin|        p1|   Ring VOLA|         2|      3|       30.0|\n| Munich|        p2|  Ring POROG|         1|      3|       90.0|\n| Berlin|        p2|  Ring POROG|         1|      1|       30.0|\n| Munich|        p3|Ring TISHINA|         1|      1|        7.0|\n| Berlin|        p3|Ring TISHINA|         1|      5|       35.0|\n+-------+----------+------------+----------+-------+-----------+\n\n+-------+----------+------------+----------+-------+-----------+\n|   city|product_id|product_name|orders_cnt|qty_sum|revenue_sum|\n+-------+----------+------------+----------+-------+-----------+\n| Berlin|        p3|Ring TISHINA|         1|      5|       35.0|\n| Berlin|        p1|   Ring VOLA|         2|      3|       30.0|\n| Berlin|        p2|  Ring POROG|         1|      1|       30.0|\n|Hamburg|        p1|   Ring VOLA|         1|     10|      100.0|\n| Munich|        p2|  Ring POROG|         1|      3|       90.0|\n| Munich|        p3|Ring TISHINA|         1|      1|        7.0|\n+-------+----------+------------+----------+-------+-----------+\n\nКоличество записей после агрегации: 6\n"
          }
        ]
      }
    },
    {
      "text": "%spark.pyspark\nfrom pyspark.sql import functions as F\nfrom pyspark.sql.window import Window\n\nprint(\"Исходные агрегированные данные:\")\nagg_df.show()\n\n# Создаём оконную спецификацию для каждого города, сортируем по убыванию выручки\nwindow_spec = Window.partitionBy(\"city\").orderBy(F.col(\"revenue_sum\").desc())\n\n# Добавляем колонку с рангом (порядковым номером) внутри каждого города\ndf_with_rank = agg_df.withColumn(\"rank\", F.row_number().over(window_spec))\n\nprint(\"Данные с рангами внутри городов:\")\ndf_with_rank.orderBy(\"city\", \"rank\").show()\n\n# Оставляем только Top-2 товара для каждого города (rank <= 2)\ntop2_df = df_with_rank.filter(F.col(\"rank\") <= 2)\n\nprint(\"Топ-2 товара по выручке в каждом городе:\")\ntop2_df.orderBy(\"city\", \"rank\").show()\n\n# Для красоты - можно убрать колонку rank из финального результата\ntop2_final = top2_df.drop(\"rank\")\nprint(\"Финальный результат (без колонки rank):\")\ntop2_final.orderBy(\"city\", F.col(\"revenue_sum\").desc()).show()",
      "user": "anonymous",
      "dateUpdated": "2026-03-02T11:55:38+0000",
      "progress": 0,
